---
import Layout from '../layouts/Layout.astro';
import { Mail, MailOpen } from "@lucide/astro"
---

<Layout>
	<div style="display: grid; grid-template-columns: 1fr 2fr; min-height: 100vh;">
		<div style="display: grid; grid-template-rows: 1fr 2fr;">
			<div box-="square" id="contact" style="display: flex; flex-direction: column; align-items: center;">
				<h1>sahana.dev</h1>
				<a href="mailto:contact@sahana.dev">
                    <div id="mail">
                        <span id="mail-container">
                            <Mail class="mail-icon mail-closed" />
                            <MailOpen class="mail-icon mail-open" />
                        </span>
                        <span id="mail-user">contact</span>@sahana.dev
                    </div>
				</a>
			</div>
			<div box-="square" id="projects">2</div>
		</div>
		<div box-="square" id="main">3</div>
	</div>
</Layout>

<style>
	#contact {
		display: flex;
		justify-content: center;
	}
	#contact h1 {
		font-size: 2rem;
		font-style: italic;
		margin-top: 1lh;
	}
	
	#mail {
		display: inline-flex;
		align-items: center;
	}
	
	#mail-container {
		display: inline-grid;
		place-items: center;
		width: 1em;
		height: 1em;
		margin-right: 1ch;
		flex: 0 0 auto;
	}
	
	.mail-icon {
		grid-area: 1 / 1;
		width: 1em;
		height: 1em;
	}

	#mail-user {
		display: inline-block;
		text-align: right;
		width: 8ch;
	}
	
	.mail-open {
		opacity: 0;
		/* Within the shared 24x24 viewBox, mail-open's envelope body bottom
		   sits at y=22 vs mail's rect bottom at y=20, so its visual bottom
		   renders 2/24em lower. Shift it up to keep the bottom edge aligned. */
		transform: translateY(calc(-2em / 24));
	}
	
	#mail:hover .mail-closed {
		opacity: 0;
	}
	
	#mail:hover .mail-open {
		opacity: 1;
	}
</style>

<script>
	const mail = document.getElementById("mail")
	const mailUser = document.getElementById("mail-user")
	const potentialUsers = [
		"sahana",
		"contact",
		"XDDCC",
		"aasdg",
		"implodes",
		"waffles",
		"*",
	]
	function changeMailUser() {
		if (!mailUser) {
			throw new Error("mailUser (id: mail-user) is missing")
		}
		mailUser.textContent = potentialUsers[Math.floor(Math.random() * potentialUsers.length)]
	}

	if (!mail) {
		throw new Error("mail (id: mail) is missing")
	}
	mail.addEventListener("mouseenter", changeMailUser)
</script>
