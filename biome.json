{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedAttributes": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on"
			}
		}
	},
	"files": {
		"includes": ["src/**"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "always",
			"semicolons": "always",
			"trailingCommas": "es5"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"complexity": {
				"useLiteralKeys": "off"
			},
			"nursery": {
				"noDivRegex": "error",
				"noDuplicateVariableNames": "error"
			},
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConsistentArrayType": {
					"level": "warn",
					"options": {
						"syntax": "shorthand"
					}
				},
				"useNamingConvention": {
					"level": "warn",
					"options": {
						"conventions": [
							{
								"formats": ["camelCase", "PascalCase"],
								"selector": { "kind": "variable" }
							},
							{
								"formats": ["camelCase"],
								"selector": { "kind": "function" }
							},
							{
								"formats": ["PascalCase"],
								"selector": { "kind": "typeLike" }
							},
							{
								"formats": ["camelCase", "snake_case", "CONSTANT_CASE"],
								"selector": { "kind": "typeProperty" }
							},
							{
								"formats": ["camelCase", "snake_case", "PascalCase", "CONSTANT_CASE"],
								"selector": { "kind": "objectLiteralProperty" }
							}
						],
						"strictCase": false
					}
				}
			}
		}
	}
}
